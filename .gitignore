# ══════════════════════════════════════════════════════════════════════════════
# SECRETS — never commit (live account session cookies)
# ══════════════════════════════════════════════════════════════════════════════
# live ChatGPT / Google account login — never commit
vendor/*/cookies.json
*.pem
*.key
# .env holds ALL keys incl. the paid ElevenLabs key → NEVER commit.
# Committed template lives in .env.example (placeholders only).
.env
config.env
# vendor/flow/config.env too (no secrets, just project ID + ports).

# ─── runtime workspace (regenerated per video, never commit) ──────────────────
project/
output/
vendor/*/output/

# ─── bundled Flow server runtime (Python/uv) — regenerated, don't commit ──────
vendor/flow/.venv/
vendor/flow/uv.lock

# ─── personal assets (privacy — don't publish) ────────────────────────────────
profile/avatar.jpg
profile/avatar.png
profile/avatar.jpeg
profile/avatar.webp
profile/profile.json
profile/topic_history.json

# ─── remotion build artifacts ─────────────────────────────────────────────────
remotion/node_modules/
remotion/out/
remotion/public/avatar
remotion/public/broll
remotion/public/sfx
remotion/public/bg_music.mp3
remotion/props/caption.json

# ─── build / render caches (regenerated, huge — never commit) ─────────────────
.cache/
.remotion/
*.egg-info/

# ─── generated runtime output (per-video, not source) ─────────────────────────
vendor/flow/media-id.js
vendor/gemini/music_raw_body.txt

# ─── logs / runtime cruft ─────────────────────────────────────────────────────
vendor/*/server.log
*.log

# ─── python / editor / os cruft ───────────────────────────────────────────────
__pycache__/
*.pyc
.DS_Store
.claude/
.cc-writes/
