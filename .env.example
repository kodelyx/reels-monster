# ==============================================================================
# reels-monster — configuration (SINGLE source of truth)
# ==============================================================================
# ⚠️ ONLY service endpoints, model names, and API keys go here.
#    PATHS are NOT configured here — they are derived from the project root by
#    core/config.py (PATHS class). This is the P1 fix: no more hardcoded absolute
#    paths that disagree across files. Move/rename the folder and it still works.
# ==============================================================================

# ─── AI text pipeline (Claude proxy, multi-key failover) ──────────────────────
# Comma-separated keys: auto-switches to the next on rate-limit / auth errors.
AI_API_KEY=your-key-here,optional-backup-key
AI_BASE_URL=https://cc.freemodel.dev
AI_MODEL=claude-sonnet-5

# ─── ElevenLabs Forced Alignment (Stage 06 word-level caption timing) ─────────
# PAID key. Get one at https://elevenlabs.io → Profile → API Key.
# Put the real key in .env (git-ignored), NOT here.
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# ─── Local service endpoints ──────────────────────────────────────────────────
# ChatGPT (caption-timing FALLBACK + AI-chat fallback) — bundled self-contained
# server. Word-level caption timing ab ElevenLabs karta hai (upar); ye tabhi chalta
# hai jab ELEVENLABS_API_KEY khaali ho ya 11lab fail ho jaaye.
# The bridge binary lives in this repo at vendor/chatgpt/chatgpt-server (a native
# macOS build of kodelyx/chatgpt-free-api) and is started ON-DEMAND by the pipeline
# (no Docker, no OrbStack). It reads vendor/chatgpt/cookies.json (synced by the
# ChatGPT Chrome extension over ws://localhost:9225) and writes to vendor/chatgpt/output/.
# Defaults below are auto-derived; override only to point elsewhere.
#   CHATGPT_SERVER_BIN=/abs/path/to/chatgpt-server   (default: vendor/chatgpt/chatgpt-server)
#   CHATGPT_SERVER_DIR=/abs/path/to/workdir          (default: vendor/chatgpt)
CHATGPT_SERVER_URL=http://localhost:9225
CHATGPT_MODEL=auto
FLOW_API_URL=http://localhost:8001

# ─── Gemini (music + AI-chat fallback) — bundled self-contained server ────────
# The Gemini server binary lives in this repo at vendor/gemini/gemini-server and
# is started ON-DEMAND by the pipeline (no Docker, no MCP, no external checkout).
# It reads vendor/gemini/cookies.json (synced by the Gemini Chrome extension over
# ws://localhost:9226) and writes tracks to vendor/gemini/output/.
# Defaults below are auto-derived; override only to point elsewhere.
#   GEMINI_SERVER_BIN=/abs/path/to/gemini-server     (default: vendor/gemini/gemini-server)
#   GEMINI_SERVER_DIR=/abs/path/to/workdir           (default: vendor/gemini)
GEMINI_MUSIC_URL=http://localhost:8002

# ─── Popup icons (stage 10 render toggle) ────────────────────────────────────
# true  = render the icon popups + their SFX (default).
# false = render WITHOUT popups. Stage 07 need NOT re-run — popup data stays in
#         caption.json; render just reads a popup-stripped copy. Flip back to
#         true and re-render to bring icons back (no AI cost).
ENABLE_POPUPS=true

